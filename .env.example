# Environment
ENVIRONMENT=development

# Server
SERVER_PORT=7070

# Database
DATABASE_URL=jdbc:postgresql://localhost:5432/taskly
DATABASE_USER=postgres
DATABASE_PASSWORD=your_secure_password_here

# JWT
JWT_SECRET=your_256_bit_secret_key_here_minimum_32_characters_long
JWT_ISSUER=taskly-api
JWT_EXPIRATION_MS=3600000
REFRESH_TOKEN_EXPIRATION_DAYS=30

# Security
BCRYPT_ROUNDS=12
RATE_LIMIT_MAX_REQUESTS=100
RATE_LIMIT_WINDOW_SECONDS=60
AUTH_RATE_LIMIT_MAX_REQUESTS=5

# CORS
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:4200

# DeepFace (Face Recognition) - Novo sistema compatível com Apple Silicon
DEEPFACE_URL=http://localhost:8080
DEEPFACE_THRESHOLD=0.4

# CompreFace (DEPRECATED - mantido para compatibilidade)
# Use DeepFace para melhor performance e compatibilidade ARM64
COMPREFACE_URL=http://localhost:8000
COMPREFACE_API_KEY=00000000-0000-0000-0000-000000000000
