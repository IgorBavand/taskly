# DeepFace Service Configuration

# Model Configuration
DEEPFACE_MODEL_NAME=Facenet512
# Options: VGG-Face, Facenet, Facenet512, OpenFace, DeepFace, DeepID, ArcFace, Dlib, SFace

# Distance Metric
DEEPFACE_DISTANCE_METRIC=cosine
# Options: cosine, euclidean, euclidean_l2

# Detector Backend
DEEPFACE_DETECTOR_BACKEND=opencv
# Options: opencv, ssd, dlib, mtcnn, retinaface, mediapipe

# Verification Threshold (lower = stricter)
DEEPFACE_VERIFICATION_THRESHOLD=0.4

# Enforce face detection (reject if no face found)
DEEPFACE_ENFORCE_DETECTION=true
